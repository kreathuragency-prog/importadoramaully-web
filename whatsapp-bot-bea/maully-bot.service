[Unit]
Description=Maully WhatsApp Bot (Bea)
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/root/maully-bot
Environment=PATH=/root/maully-bot/venv/bin:/usr/local/bin:/usr/bin
ExecStart=/root/maully-bot/venv/bin/uvicorn main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
